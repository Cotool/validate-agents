{
  "name": "validate-agents-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that validates Cotool Response-Agents-as-Code YAML against the Cotool validate API.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/glob": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
